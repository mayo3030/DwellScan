# DwellScan Environment Configuration
# Copy to .env and fill in values

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/dwellscan"

# Auth
JWT_SECRET="your-secret-key-at-least-32-chars-long"
JWT_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PLATFORM_FEE_BPS=1000
# Platform fee in basis points (1000 = 10%)

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="DwellScan"

# AI Scan (placeholder for future integration)
AI_SCAN_API_KEY=""
AI_SCAN_API_URL=""

# Email (placeholder)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
